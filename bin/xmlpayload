#!/usr/bin/env bash
# Extract a JSON string field (default: Payload) and pretty-print it as XML.
#
# Usage:
#   xmlpayload [FILE] [-f FIELD]
#
# Reads from FILE, or stdin if FILE is omitted or "-".
# The chosen field is expected to contain an escaped XML string.
set -euo pipefail

field="Payload"
file="-"

while [[ $# -gt 0 ]]; do
    case "$1" in
    -f | --field)
        field="$2"
        shift 2
        ;;
    -h | --help)
        sed -n '2,10p' "$0" | sed 's/^# \{0,1\}//'
        exit 0
        ;;
    *)
        file="$1"
        shift
        ;;
    esac
done

if [[ "$file" == "-" ]]; then
    jq -r --arg f "$field" '.[$f]' | xmllint --format -
else
    jq -r --arg f "$field" '.[$f]' "$file" | xmllint --format -
fi
